    <members>
        <member name="T:FiftyOne.IpIntelligence.Countries.FlowElements.IpCountriesElement">
             <summary>
             A post-processing flow element that produces flat (non-weighted) country
             code lists by combining weighted results from the IPI engine with the
             full set of possible country codes from metadata.
            
             The results are written directly to the <see cref="T:FiftyOne.IpIntelligence.IIpIntelligenceData"/>
             object's <c>CountryCodesGeographicalAll</c> and
             <c>CountryCodesPopulationAll</c> properties.
            
             Must be added to the pipeline after <see cref="T:FiftyOne.IpIntelligence.Engine.OnPremise.FlowElements.IpiOnPremiseEngine"/>.
             </summary>
        </member>
